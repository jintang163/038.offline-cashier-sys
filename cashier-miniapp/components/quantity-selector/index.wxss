.quantity-selector {
  display: flex;
  align-items: center;
}

.btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.btn.minus {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.btn.add {
  background-color: #ff6b35;
  color: white;
}

.btn.disabled {
  opacity: 0.4;
}

.quantity-input {
  width: 80rpx;
  height: 56rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  margin: 0 12rpx;
}
