.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.network-status {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.network-status.online {
  background: #e8f5e9;
  color: #2e7d32;
}

.network-status.offline {
  background: #ffebee;
  color: #c62828;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.currency-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.currency-label {
  font-size: 26rpx;
  color: #666;
}

.currency-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b35;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item.selected {
  background: #fff3e0;
  border-color: #ff6b35;
}

.option-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.option-symbol {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b35;
  min-width: 60rpx;
}

.option-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.option-code {
  font-size: 24rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.option-rate {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-right: 20rpx;
}

.rate-label {
  font-size: 22rpx;
  color: #999;
}

.rate-value {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff6b35;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

.sync-rates {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  margin-top: 20rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  border-radius: 12rpx;
  color: #fff;
  font-size: 28rpx;
}

.sync-icon {
  font-size: 32rpx;
}

.cache-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
  justify-content: center;
}

.cache-expired {
  color: #ff9800;
}

.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn-home,
.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.btn-home {
  background: #f5f5f5;
  color: #666;
}

.btn-back {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #fff;
}
