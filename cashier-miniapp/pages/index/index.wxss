.index-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: #f5f5f5;
}

.network-tip {
  background-color: #fff3cd;
  color: #856404;
  text-align: center;
  padding: 16rpx;
  font-size: 24rpx;
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.header-info {
  flex: 1;
}

.lang-currency {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #666;
}

.lang-text {
  color: #ff6b35;
  font-weight: 500;
}

.separator {
  color: #ddd;
}

.currency-text {
  color: #333;
}

.settings-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

.main-content {
  flex: 1;
  display: flex;
  overflow: hidden;
  padding-bottom: 120rpx;
}

.category-sidebar {
  width: 180rpx;
  background-color: #f0f0f0;
  height: 100%;
}

.category-item {
  padding: 32rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.category-item.active {
  background-color: white;
  color: #ff6b35;
  font-weight: 500;
}

.category-item.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 40rpx;
  background-color: #ff6b35;
  border-radius: 0 4rpx 4rpx 0;
}

.goods-list {
  flex: 1;
  padding: 20rpx;
  height: 100%;
}

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx 0 0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.cart-info {
  flex: 1;
  display: flex;
  align-items: center;
  padding-left: 30rpx;
}

.cart-icon-wrapper {
  position: relative;
  margin-right: 20rpx;
}

.cart-icon {
  font-size: 48rpx;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background-color: #ff6b35;
  color: white;
  font-size: 20rpx;
  border-radius: 16rpx;
  text-align: center;
}

.cart-total {
  display: flex;
  flex-direction: column;
}

.total-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.foreign-price {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
  font-weight: normal;
}

.total-tip {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.go-pay-btn {
  width: 200rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background-color: #ff6b35;
  color: white;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.go-pay-btn:active {
  background-color: #e55a2b;
}
