<view class="order-confirm-page">
  <view class="header-actions">
    <view class="back-btn" bindtap="onGoBack">
      <text>←</text>
    </view>
    <view class="settings-btn" bindtap="onGoToSettings">
      <text>⚙️</text>
    </view>
  </view>

  <view class="section">
    <view class="section-title">{{i18n['order.createOrder']}}</view>
    <view class="form-item">
      <text class="form-label">{{i18n['order.tableNumber']}}</text>
      <picker bindchange="onTableChange" value="{{tablePickerIndex}}" range="{{tableOptions}}">
        <view class="form-picker">
          <text class="{{tableNumber ? '' : 'placeholder'}}">{{tableNumber || i18n['order.selectTablePlaceholder']}}</text>
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">{{i18n['order.peopleCount']}}</text>
      <view class="form-value">
        <input
          class="people-input"
          type="number"
          value="{{peopleCount}}"
          bindinput="onPeopleChange"
          placeholder="{{i18n['order.peoplePlaceholder']}}"
        />
        <text class="unit">{{i18n['common.person']}}</text>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">{{i18n['order.remark']}}</text>
      <input
        class="form-input"
        placeholder="{{i18n['order.remarkPlaceholder']}}"
        value="{{remark}}"
        bindinput="onRemarkInput"
        maxlength="50"
      />
    </view>
  </view>

  <view class="section">
    <view class="section-title">{{i18n['order.goodsDetail']}}</view>
    <view class="goods-list">
      <view wx:for="{{cartList}}" wx:key="id" class="goods-item">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-name text-ellipsis">{{item.name}}</view>
          <view class="goods-price">¥{{item.price}}</view>
        </view>
        <view class="goods-quantity">x{{item.quantity}}</view>
      </view>
    </view>
  </view>

  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">{{i18n['order.goodsSubtotal']}}</text>
      <text class="price-value">¥{{cartTotal}}</text>
    </view>
    <view class="price-row" wx:if="{{selectedCurrency !== 'CNY' && foreignAmount > 0}}">
      <text class="price-label">{{selectedCurrency}} 合计</text>
      <text class="price-value">{{currencySymbol}}{{foreignAmount}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">{{i18n['order.deliveryFee']}}</text>
      <text class="price-value">¥0.00</text>
    </view>
    <view class="divider"></view>
    <view class="price-row total-row">
      <text class="price-label">{{i18n['order.totalAmount']}}</text>
      <text class="total-price">¥{{cartTotal}}</text>
    </view>
    <view class="currency-info" wx:if="{{selectedCurrency !== 'CNY'}}">
      <text class="currency-tip">1 {{selectedCurrency}} = ¥{{currentRate}}</text>
    </view>
  </view>

  <view class="submit-bar">
    <view class="submit-total">
      <text class="total-label">{{i18n['common.total']}}：</text>
      <text class="total-amount">¥{{cartTotal}}</text>
      <text class="foreign-total" wx:if="{{selectedCurrency !== 'CNY'}}">
        ({{currencySymbol}}{{foreignAmount}})</text>
    </view>
    <view class="submit-btn {{isSubmitting ? 'disabled' : ''}}" bindtap="onSubmitOrder">
      {{isSubmitting ? i18n['common.loading'] : i18n['common.confirm']}}
    </view>
  </view>

  <view class="pay-options-mask" wx:if="{{showPayOptions}}" bindtap="onClosePayOptions">
    <view class="pay-options" catchtap="">
      <view class="pay-options-header">
        <text class="pay-options-title">{{i18n['payment.payMethod']}}</text>
        <view class="pay-options-close" bindtap="onClosePayOptions">✕</view>
      </view>
      <view class="pay-options-list">
        <view class="pay-option-item" bindtap="onSelectPayMethod" data-method="cash">
          <text class="pay-option-icon">💴</text>
          <text class="pay-option-name">{{i18n['payment.cashPayment']}}</text>
          <text class="pay-option-arrow">></text>
        </view>
        <view class="pay-option-item" bindtap="onSelectPayMethod" data-method="foreign">
          <text class="pay-option-icon">💱</text>
          <text class="pay-option-name">{{i18n['payment.foreignCurrency']}}</text>
          <text class="pay-option-desc">{{i18n['payment.selectCurrency']}}</text>
          <text class="pay-option-arrow">></text>
        </view>
        <view class="pay-option-item" bindtap="onSelectPayMethod" data-method="wechat">
          <text class="pay-option-icon">💚</text>
          <text class="pay-option-name">{{i18n['payment.wechatPay']}}</text>
          <text class="pay-option-arrow">></text>
        </view>
        <view class="pay-option-item" bindtap="onSelectPayMethod" data-method="alipay">
          <text class="pay-option-icon">💙</text>
          <text class="pay-option-name">{{i18n['payment.alipay']}}</text>
          <text class="pay-option-arrow">></text>
        </view>
      </view>
    </view>
  </view>
</view>
