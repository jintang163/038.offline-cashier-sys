<view class="order-confirm-page">
  <view class="section">
    <view class="section-title">就餐信息</view>
    <view class="form-item">
      <text class="form-label">桌号</text>
      <picker bindchange="onTableChange" value="{{tablePickerIndex}}" range="{{tableOptions}}">
        <view class="form-picker">
          <text class="{{tableNumber ? '' : 'placeholder'}}">{{tableNumber || '请选择桌号'}}</text>
          <text class="picker-arrow">></text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">用餐人数</text>
      <view class="form-value">
        <input
          class="people-input"
          type="number"
          value="{{peopleCount}}"
          bindinput="onPeopleChange"
          placeholder="请输入人数"
        />
        <text class="unit">人</text>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">备注</text>
      <input
        class="form-input"
        placeholder="请输入备注（选填）"
        value="{{remark}}"
        bindinput="onRemarkInput"
        maxlength="50"
      />
    </view>
  </view>

  <view class="section">
    <view class="section-title">商品明细</view>
    <view class="goods-list">
      <view wx:for="{{cartList}}" wx:key="id" class="goods-item">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-name text-ellipsis">{{item.name}}</view>
          <view class="goods-price">{{item.price}}</view>
        </view>
        <view class="goods-quantity">x{{item.quantity}}</view>
      </view>
    </view>
  </view>

  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">商品合计</text>
      <text class="price-value">{{cartTotal}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">配送费</text>
      <text class="price-value">¥0.00</text>
    </view>
    <view class="divider"></view>
    <view class="price-row total-row">
      <text class="price-label">实付金额</text>
      <text class="total-price">{{cartTotal}}</text>
    </view>
  </view>

  <view class="submit-bar">
    <view class="submit-total">
      <text class="total-label">合计：</text>
      <text class="total-amount">{{cartTotal}}</text>
    </view>
    <view class="submit-btn {{isSubmitting ? 'disabled' : ''}}" bindtap="onSubmitOrder">
      {{isSubmitting ? '提交中...' : '提交订单'}}
    </view>
  </view>
</view>
