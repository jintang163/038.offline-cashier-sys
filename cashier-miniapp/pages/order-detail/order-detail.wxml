<view class="order-detail-page" wx:if="{{order}}">
  <view class="status-header">
    <view class="status-icon">🍽️</view>
    <view class="status-info">
      <text class="status-text" style="color: {{statusColor}}">{{statusText}}</text>
      <text class="status-tip" wx:if="{{order.status === 'pending'}}">请尽快完成支付</text>
      <text class="status-tip" wx:elif="{{order.status === 'preparing'}}">正在为您准备中</text>
      <text class="status-tip" wx:elif="{{order.status === 'completed'}}">订单已完成，感谢您的惠顾</text>
      <text class="status-tip" wx:elif="{{order.status === 'cancelled'}}">订单已取消</text>
    </view>
  </view>

  <view class="section info-section">
    <view class="info-row">
      <text class="info-label">桌号</text>
      <text class="info-value">{{order.tableNumber}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">用餐人数</text>
      <text class="info-value">{{order.peopleCount}}人</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">备注</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
  </view>

  <view class="section goods-section">
    <view class="section-title">商品明细</view>
    <view class="goods-list">
      <view wx:for="{{order.goods}}" wx:key="id" class="goods-item">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-name text-ellipsis">{{item.name}}</view>
          <view class="goods-price">{{item.price}}</view>
        </view>
        <view class="goods-quantity">x{{item.quantity}}</view>
      </view>
    </view>
    <view class="goods-total">
      <text>共{{goodsCount}}件商品</text>
    </view>
  </view>

  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">商品金额</text>
      <text class="price-value">¥{{order.totalAmount}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">配送费</text>
      <text class="price-value">¥0.00</text>
    </view>
    <view class="divider"></view>
    <view class="price-row total-row">
      <text class="price-label">实付金额</text>
      <text class="total-price">{{order.totalAmount}}</text>
    </view>
  </view>

  <view class="section order-info-section">
    <view class="info-row">
      <text class="info-label">订单号</text>
      <text class="info-value order-no">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">下单时间</text>
      <text class="info-value">{{createTimeText}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">联系客服</text>
      <text class="info-value link" bindtap="onCallPhone">400-123-4567</text>
    </view>
  </view>

  <view class="bottom-bar">
    <view wx:if="{{order.status === 'pending'}}" class="bar-actions">
      <view class="action-btn cancel" bindtap="onCancelOrder">取消订单</view>
      <view class="action-btn primary" bindtap="onPayOrder">去支付</view>
    </view>
    <view wx:elif="{{order.status === 'completed'}}" class="bar-actions">
      <view class="action-btn primary" bindtap="onReorder">再来一单</view>
    </view>
    <view wx:else class="bar-actions">
      <view class="action-btn primary" bindtap="onGoMenu">返回菜单</view>
    </view>
  </view>
</view>

<view wx:else class="empty">
  <text>订单不存在</text>
</view>
