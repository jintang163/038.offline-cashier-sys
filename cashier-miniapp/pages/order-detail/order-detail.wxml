<view class="order-detail-page" wx:if="{{order}}">
  <view class="status-header">
    <view class="status-icon">🍽️</view>
    <view class="status-info">
      <text class="status-text" style="color: {{statusColor}}">{{statusText}}</text>
      <text class="status-tip" wx:if="{{order.status === 'pending'}}">{{i18n['order.payPrompt']}}</text>
      <text class="status-tip" wx:elif="{{order.status === 'preparing'}}">{{i18n['order.preparingPrompt']}}</text>
      <text class="status-tip" wx:elif="{{order.status === 'completed'}}">{{i18n['order.completedPrompt']}}</text>
      <text class="status-tip" wx:elif="{{order.status === 'cancelled'}}">{{i18n['order.cancelledPrompt']}}</text>
    </view>
  </view>

  <view class="section info-section">
    <view class="info-row">
      <text class="info-label">{{i18n['order.tableNumber']}}</text>
      <text class="info-value">{{order.tableNumber}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">{{i18n['order.peopleCount']}}</text>
      <text class="info-value">{{order.peopleCount}}{{i18n['common.person']}}</text>
    </view>
    <view class="info-row" wx:if="{{order.remark}}">
      <text class="info-label">{{i18n['order.remark']}}</text>
      <text class="info-value">{{order.remark}}</text>
    </view>
  </view>

  <view class="section goods-section">
    <view class="section-title">{{i18n['order.goodsDetail']}}</view>
    <view class="goods-list">
      <view wx:for="{{order.goods}}" wx:key="id" class="goods-item">
        <image class="goods-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="goods-info">
          <view class="goods-name text-ellipsis">{{item.name}}</view>
          <view class="goods-price">{{item.price}}</view>
        </view>
        <view class="goods-quantity">x{{item.quantity}}</view>
      </view>
    </view>
    <view class="goods-total">
      <text>{{goodsCountText}}</text>
    </view>
  </view>

  <view class="section price-section">
    <view class="price-row">
      <text class="price-label">{{i18n['order.goodsSubtotal']}}</text>
      <text class="price-value">¥{{order.totalAmount}}</text>
    </view>
    <view class="price-row">
      <text class="price-label">{{i18n['order.deliveryFee']}}</text>
      <text class="price-value">¥0.00</text>
    </view>
    <view class="divider"></view>
    <view class="price-row total-row">
      <text class="price-label">{{i18n['order.actualPay']}}</text>
      <text class="total-price">{{order.totalAmount}}</text>
    </view>
  </view>

  <view class="section order-info-section">
    <view class="info-row">
      <text class="info-label">{{i18n['order.orderNo']}}</text>
      <text class="info-value order-no">{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">{{i18n['order.orderTime']}}</text>
      <text class="info-value">{{createTimeText}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">{{i18n['order.contactService']}}</text>
      <text class="info-value link" bindtap="onCallPhone">400-123-4567</text>
    </view>
  </view>

  <view class="bottom-bar">
    <view wx:if="{{order.status === 'pending'}}" class="bar-actions">
      <view class="action-btn cancel" bindtap="onCancelOrder">{{i18n['order.cancelOrder']}}</view>
      <view class="action-btn primary" bindtap="onPayOrder">{{i18n['order.payNow']}}</view>
    </view>
    <view wx:elif="{{order.status === 'completed'}}" class="bar-actions">
      <view class="action-btn primary" bindtap="onReorder">{{i18n['order.reorder']}}</view>
    </view>
    <view wx:else class="bar-actions">
      <view class="action-btn primary" bindtap="onGoMenu">{{i18n['order.backMenu']}}</view>
    </view>
  </view>
</view>

<view wx:else class="empty">
  <text>{{i18n['order.orderNotExist']}}</text>
</view>
