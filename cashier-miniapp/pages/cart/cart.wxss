.cart-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.go-menu-btn {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background-color: #ff6b35;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.cart-content {
  padding: 20rpx;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 10rpx;
}

.cart-title {
  font-size: 28rpx;
  color: #666;
}

.edit-btn {
  font-size: 26rpx;
  color: #ff6b35;
}

.cart-list {
  max-height: calc(100vh - 240rpx);
}

.cart-item {
  display: flex;
  padding: 24rpx;
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.item-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.item-price {
  font-size: 32rpx;
  color: #ff6b35;
  font-weight: bold;
}

.item-price::before {
  content: '¥';
  font-size: 0.8em;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.btn.minus {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #e0e0e0;
}

.btn.add {
  background-color: #ff6b35;
  color: white;
}

.quantity-num {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  color: #333;
  margin: 0 12rpx;
}

.delete-btn {
  font-size: 24rpx;
  color: #ff6b35;
  padding: 8rpx 16rpx;
  border: 1rpx solid #ff6b35;
  border-radius: 6rpx;
}

.clear-cart {
  text-align: center;
  padding: 30rpx;
  color: #999;
  font-size: 26rpx;
}

.settle-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background-color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 0 0 40rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.total-info {
  flex: 1;
  display: flex;
  align-items: baseline;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-price {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b35;
}

.total-price::before {
  content: '¥';
  font-size: 0.7em;
}

.settle-btn {
  width: 240rpx;
  height: 100%;
  line-height: 100rpx;
  text-align: center;
  background-color: #ff6b35;
  color: white;
  font-size: 30rpx;
  font-weight: 500;
}

.settle-btn:active {
  background-color: #e55a2b;
}
