<view class="container" wx:if="{{task}}">
  <view class="scan-header">
    <view class="task-info">
      <view class="task-name">{{task.task_name}}</view>
      <view class="task-no">任务编号：{{task.task_no}}</view>
    </view>
    <view class="network-status {{networkStatus ? 'online' : 'offline'}}">
      {{networkStatus ? '📡 在线' : '📵 离线'}}
    </view>
  </view>

  <view class="progress-card">
    <view class="progress-header">
      <text class="progress-title">盘点进度</text>
      <text class="progress-text">{{progress.checked}}/{{progress.total}} ({{progress.progress}}%)</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress.progress}}%;"></view>
    </view>
  </view>

  <view class="scan-btn-wrap">
    <button class="scan-btn" bindtap="scanCode">
      <text class="scan-icon">📷</text>
      <text class="scan-text">扫码盘点</text>
      <text class="scan-tip">点击扫描商品条码</text>
    </button>
  </view>

  <view class="section-title">
    <text>商品列表</text>
    <text class="count">({{items.length}})</text>
  </view>

  <scroll-view scroll-y class="item-list">
    <view 
      class="item-card {{item.check_status === 1 ? 'checked' : ''}}" 
      wx:for="{{items}}" 
      wx:key="id"
      bindtap="viewItemDetail"
      data-id="{{item.id}}"
    >
      <view class="item-header">
        <view class="item-name">{{item.product_name}}</view>
        <view class="item-status {{item.check_status === 1 ? 'checked' : 'unchecked'}}">
          {{item.statusText}}
        </view>
      </view>
      <view class="item-info">
        <view class="info-row">
          <text class="label">分类:</text>
          <text class="value">{{item.category_name}}</text>
        </view>
        <view class="info-row">
          <text class="label">条码:</text>
          <text class="value">{{item.barcode || '-'}}</text>
        </view>
        <view class="info-row">
          <text class="label">理论:</text>
          <text class="value theory">{{item.theoretical_stock}} {{item.unit}}</text>
        </view>
        <view class="info-row">
          <text class="label">实盘:</text>
          <text class="value actual">{{item.actual_stock !== null ? item.actual_stock : '-'}} {{item.unit}}</text>
        </view>
      </view>
      <view class="item-input">
        <input 
          class="quantity-input"
          type="number"
          placeholder="点击输入数量"
          value="{{item.actual_stock || ''}}"
          data-id="{{item.id}}"
          bindblur="onQuantityChange"
          catchtap="onQuantityInput"
        />
      </view>
    </view>
  </scroll-view>

  <view class="section-title" wx:if="{{scanRecords.length > 0}}">
    <text>扫码记录</text>
    <text class="count">({{scanRecords.length}})</text>
  </view>

  <scroll-view scroll-y class="record-list" wx:if="{{scanRecords.length > 0}}">
    <view class="record-card" wx:for="{{scanRecords}}" wx:key="local_id">
      <view class="record-info">
        <view class="record-barcode">条码：{{item.barcode}}</view>
        <view class="record-time">{{item.scan_time}}</view>
      </view>
      <view class="record-quantity">数量：{{item.input_quantity}}</view>
      <view class="record-delete" bindtap="deleteRecord" data-id="{{item.local_id}}" catchtap="deleteRecord">
        删除
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="btn-back" bindtap="goBack">返回</button>
    <button class="btn-upload" bindtap="goToUpload">
      <text>⬆️</text>
      <text>上传数据</text>
    </button>
  </view>
</view>
