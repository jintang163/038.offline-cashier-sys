.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 10rpx;
}

.network-status {
  display: flex;
  align-items: center;
  font-size: 28rpx;
}

.network-status.online {
  color: #52c41a;
}

.network-status.offline {
  color: #ff4d4f;
}

.network-status text {
  margin-right: 8rpx;
}

.sync-btn {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #ff6b35;
}

.sync-btn text {
  margin-right: 8rpx;
}

.header-btns {
  display: flex;
  gap: 20rpx;
}

.erp-btn {
  color: #722ed1;
}

.task-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.task-card {
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.task-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-0 {
  background: #e6f7ff;
  color: #1890ff;
}

.status-1 {
  background: #e6fffb;
  color: #13c2c2;
}

.status-2 {
  background: #fff7e6;
  color: #fa8c16;
}

.status-3 {
  background: #f6ffed;
  color: #52c41a;
}

.status-4 {
  background: #fff1f0;
  color: #ff4d4f;
}

.task-info {
  background: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  font-size: 26rpx;
  line-height: 1.8;
}

.info-item .label {
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-item .value {
  color: #333;
  flex: 1;
}

.task-actions {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 140rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.btn-primary {
  background: #ff6b35;
  color: #fff;
}

.btn-success {
  background: #52c41a;
  color: #fff;
}

.btn-warning {
  background: #fa8c16;
  color: #fff;
}

.btn-info {
  background: #1890ff;
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: #999;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 26rpx;
}
