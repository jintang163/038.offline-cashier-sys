.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  padding: 24rpx;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.task-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.task-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
}

.status-0 { background: #e6f7ff; color: #1890ff; }
.status-1 { background: #e6fffb; color: #13c2c2; }
.status-2 { background: #fff7e6; color: #fa8c16; }
.status-3 { background: #f6ffed; color: #52c41a; }
.status-4 { background: #fff1f0; color: #ff4d4f; }

.task-info {
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  gap: 40rpx;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  flex: 1;
  display: flex;
  font-size: 26rpx;
}

.info-item.full-width {
  flex: none;
  width: 100%;
}

.info-item .label {
  color: #999;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.info-item .value {
  color: #333;
  flex: 1;
}

.progress-card {
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.progress-text {
  font-size: 26rpx;
  color: #ff6b35;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ff6b35, #ff8c5a);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.category-tabs {
  background: #fff;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.tabs-scroll {
  white-space: nowrap;
}

.tab-item {
  display: inline-block;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 4rpx solid transparent;
}

.tab-item.active {
  color: #ff6b35;
  border-bottom-color: #ff6b35;
  font-weight: bold;
}

.tab-count {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
}

.tab-item.active .tab-count {
  color: #ff6b35;
}

.item-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.item-card {
  background: #fff;
  border-radius: 10rpx;
  padding: 24rpx;
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.item-status {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.item-status.checked {
  background: #f6ffed;
  color: #52c41a;
}

.item-status.unchecked {
  background: #f5f5f5;
  color: #999;
}

.item-info {
  background: #fafafa;
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.item-info .info-row {
  display: flex;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.item-info .info-row:last-child {
  margin-bottom: 0;
}

.item-info .label {
  color: #999;
  width: 120rpx;
  flex-shrink: 0;
}

.item-info .value {
  color: #333;
  flex: 1;
}

.item-info .value.theory {
  color: #1890ff;
  font-weight: bold;
}

.item-input {
  display: flex;
  align-items: center;
}

.input-label {
  font-size: 28rpx;
  color: #333;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.quantity-input {
  flex: 1;
  height: 64rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  background: #fff;
}

.quantity-input:focus {
  border-color: #ff6b35;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.btn-scan, .btn-upload {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
}

.btn-scan {
  background: #fa8c16;
  color: #fff;
}

.btn-upload {
  background: #1890ff;
  color: #fff;
}

.btn-scan text:first-child,
.btn-upload text:first-child {
  margin-right: 8rpx;
  font-size: 32rpx;
}
