.container {
  padding: 20rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
  background: #f5f5f5;
  box-sizing: border-box;
}

.order-info {
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  color: #fff;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.3);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  opacity: 0.9;
}

.info-value {
  font-size: 28rpx;
  font-weight: 500;
}

.total-row {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.2);
}

.total {
  font-size: 40rpx;
  font-weight: bold;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 36rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.currency-selector {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
}

.currency-icon {
  font-size: 40rpx;
  font-weight: bold;
  color: #ff6b35;
  min-width: 60rpx;
  text-align: center;
}

.currency-name {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.currency-arrow {
  font-size: 24rpx;
  color: #999;
}

.rate-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: #fff3e0;
  border-radius: 8rpx;
}

.rate-label {
  font-size: 26rpx;
  color: #666;
}

.rate-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #ff6b35;
  font-family: monospace;
}

.converted-amount {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding: 20rpx;
  background: #e8f5e9;
  border-radius: 8rpx;
}

.converted-label {
  font-size: 26rpx;
  color: #666;
}

.converted-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #2e7d32;
}

.amount-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 30rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #ff6b35;
}

.input-symbol {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff6b35;
  min-width: 80rpx;
  text-align: center;
}

.amount-input {
  flex: 1;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  text-align: right;
}

.quick-amounts {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.quick-btn {
  flex: 0 0 calc(33.333% - 12rpx);
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  text-align: center;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #e0e0e0;
  box-sizing: border-box;
}

.quick-btn:active {
  background: #ff6b35;
  color: #fff;
  border-color: #ff6b35;
}

.change-info {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.change-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx dashed #e0e0e0;
}

.change-row:last-child {
  border-bottom: none;
}

.change-label {
  font-size: 26rpx;
  color: #666;
}

.change-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.total-change {
  padding-top: 16rpx;
  margin-top: 8rpx;
}

.total-change .change-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.total-change .highlight {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
}

.change-sub {
  font-size: 24rpx;
  color: #999;
  font-weight: normal;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.btn-back {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  color: #666;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.btn-confirm {
  flex: 2;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #ff6b35 0%, #f7931e 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
}

.btn-confirm.disabled {
  background: #ccc;
  color: #fff;
}

.currency-picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.currency-picker {
  width: 100%;
  max-height: 70vh;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  display: flex;
  flex-direction: column;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.picker-close {
  font-size: 36rpx;
  color: #999;
  padding: 10rpx;
}

.picker-list {
  flex: 1;
  max-height: 60vh;
}

.picker-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 30rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.picker-item.selected {
  background: #fff3e0;
}

.picker-symbol {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff6b35;
  min-width: 60rpx;
  text-align: center;
}

.picker-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.picker-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.picker-code {
  font-size: 24rpx;
  color: #999;
}

.picker-rate {
  font-size: 24rpx;
  color: #666;
  font-family: monospace;
  margin-right: 16rpx;
}

.picker-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #ff6b35;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}
