.orders-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.tabs {
  display: flex;
  background-color: white;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #ff6b35;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #ff6b35;
  border-radius: 2rpx;
}

.empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.go-menu-btn {
  margin-top: 40rpx;
  padding: 20rpx 60rpx;
  background-color: #ff6b35;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.order-list {
  flex: 1;
  padding: 20rpx;
}

.order-card {
  background-color: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.order-no {
  font-size: 26rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: 500;
}

.order-content {
  display: flex;
  padding: 24rpx;
  align-items: center;
}

.goods-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  background-color: #f5f5f5;
}

.goods-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.goods-more {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.order-amount {
  text-align: right;
  flex-shrink: 0;
}

.amount-label {
  font-size: 24rpx;
  color: #999;
  display: block;
}

.amount-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff6b35;
  margin-top: 4rpx;
  display: block;
}

.amount-value::before {
  content: '¥';
  font-size: 0.7em;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: #fafafa;
}

.order-time {
  font-size: 24rpx;
  color: #999;
}

.order-actions {
  display: flex;
}

.action-btn {
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-left: 16rpx;
  border: 1rpx solid #ddd;
  background-color: white;
  color: #666;
}

.action-btn.primary {
  background-color: #ff6b35;
  color: white;
  border-color: #ff6b35;
}

.action-btn.cancel {
  color: #999;
  border-color: #ddd;
}
